---
import MobileNav from "~/components/react/MobileNav.tsx";
import SearchCommand from "~/components/react/SearchCommand.tsx";
import ThemeToggle from "~/components/react/ThemeToggle.tsx";
import { COMPONENT_GROUPS, GETTING_STARTED } from "~/lib/components-registry";

// Plain-JSON nav model for the mobile drawer island.
const navGroups = [
  {
    label: "Getting started",
    items: GETTING_STARTED.map(({ href, title }) => ({ href, title })),
  },
  ...COMPONENT_GROUPS.map((group) => ({
    label: group.label,
    items: group.items.map((entry) => ({
      href: `/components/${entry.slug}`,
      title: entry.title,
    })),
  })),
];

const navLink =
  "rounded-md px-3 py-1.5 text-body-sm-medium text-secondary hover:bg-layer-transparent-hover hover:text-primary focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-offset-1 focus-visible:outline-none";
---

<header class="sticky top-0 z-40 border-b border-subtle bg-canvas">
  <div class="mx-auto flex h-header max-w-7xl items-center gap-3 px-4 sm:px-6">
    <span class="lg:hidden">
      <MobileNav
        groups={navGroups}
        currentPath={Astro.url.pathname}
        client:media="(max-width: 63.99rem)"
      />
    </span>
    <a
      href="/"
      class="rounded-md text-h6-semibold text-primary focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-offset-1 focus-visible:outline-none"
    >
      Propel
    </a>
    <nav aria-label="Main" class="hidden items-center gap-1 sm:flex">
      <a href="/introduction" class={navLink}>Docs</a>
      <a href="/components" class={navLink}>Components</a>
    </nav>
    <div class="ml-auto flex items-center gap-1.5">
      <SearchCommand client:load />
      <a
        href="https://github.com/makeplane/propel"
        aria-label="Propel on GitHub"
        class="rounded-md p-1.5 text-icon-secondary hover:bg-layer-transparent-hover hover:text-icon-primary focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-offset-1 focus-visible:outline-none"
      >
        <svg viewBox="0 0 16 16" aria-hidden="true" class="size-4 fill-current">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
