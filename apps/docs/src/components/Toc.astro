---
export type TocHeading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: TocHeading[];
};

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 ? (
    <nav aria-label="On this page" class="flex flex-col gap-2">
      <p class="text-caption-md-medium tracking-wide text-tertiary uppercase">On this page</p>
      <ul class="flex flex-col gap-0.5 border-l border-subtle">
        {items.map((item) => (
          <li>
            <a
              href={`#${item.slug}`}
              class={`block rounded-r-md py-1 pr-2 text-body-sm-regular text-secondary hover:text-primary focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-inset focus-visible:outline-none ${
                item.depth === 3 ? "pl-6" : "pl-3"
              }`}
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  ) : null
}
