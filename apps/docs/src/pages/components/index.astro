---
import type { TocHeading } from "~/components/Toc.astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import DocsShell from "~/layouts/DocsShell.astro";
import { COMPONENT_GROUPS, COMPONENTS } from "~/lib/components-registry";

const description = `Every component in @makeplane/propel — ${COMPONENTS.length} in all, grouped by family. Each page shows the component live beside its source, with a props table generated from its real types.`;

const slugify = (label: string) =>
  label
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

// Family headings for the "On this page" rail.
const headings: TocHeading[] = COMPONENT_GROUPS.map((group) => ({
  depth: 2,
  slug: slugify(group.label),
  text: group.label,
}));
---

<BaseLayout title="Components" description={description}>
  <DocsShell headings={headings}>
    <header class="mb-8 border-b border-subtle pb-6">
      <h1 class="text-h3-semibold text-primary">Components</h1>
      <p class="mt-2 max-w-[75ch] text-body-md-regular text-secondary">{description}</p>
    </header>
    <div class="flex flex-col gap-10">
      {
        COMPONENT_GROUPS.map((group) => (
          <section>
            <h2 id={slugify(group.label)} class="text-h6-semibold text-primary">
              {group.label}
            </h2>
            <ul class="mt-3 overflow-hidden rounded-lg border border-subtle">
              {group.items.map((entry) => (
                <li class="border-b border-subtle last:border-0">
                  <a
                    href={`/components/${entry.slug}`}
                    class="flex flex-col gap-0.5 px-4 py-3 hover:bg-layer-transparent-hover focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-inset focus-visible:outline-none sm:flex-row sm:gap-4"
                  >
                    <span class="w-44 shrink-0 text-body-sm-medium text-primary">
                      {entry.title}
                    </span>
                    <span class="text-body-sm-regular text-secondary">{entry.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </DocsShell>
</BaseLayout>
