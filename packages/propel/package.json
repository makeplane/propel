{
  "name": "@makeplane/propel",
  "version": "0.1.0",
  "description": "Plane's React component library built on Base UI and Tailwind CSS v4.",
  "keywords": [
    "base-ui",
    "components",
    "design-system",
    "plane",
    "react",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://github.com/makeplane/propel/tree/main/packages/propel#readme",
  "bugs": "https://github.com/makeplane/propel/issues",
  "license": "AGPL-3.0-only",
  "author": "Plane (https://plane.so)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makeplane/propel.git",
    "directory": "packages/propel"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./base/*": {
      "types": "./dist/base/*/index.d.ts",
      "import": "./dist/base/*/index.js"
    },
    "./elements/*": {
      "types": "./dist/elements/*/index.d.ts",
      "import": "./dist/elements/*/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*/index.d.ts",
      "import": "./dist/hooks/*/index.js"
    },
    "./styles": "./dist/styles/propel.css",
    "./styles/*": "./dist/styles/*.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "build-storybook": "storybook build",
    "storybook": "storybook dev -p 6006",
    "check:lint": "oxlint --type-aware -c ../../.oxlintrc.json .",
    "check:format": "oxfmt . --check",
    "check:types": "tsc --noEmit --declaration false --declarationMap false",
    "fix:lint": "oxlint --type-aware --fix -c ../../.oxlintrc.json .",
    "fix:format": "oxfmt . --write",
    "clean": "rm -rf .turbo node_modules dist storybook-static",
    "pretest": "if [ \"$CI\" = \"true\" ]; then playwright install --with-deps chromium; else playwright install chromium; fi",
    "test": "vitest run --project=storybook"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "catalog:",
    "react-day-picker": "^10.0.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "playwright": "catalog:",
    "publint": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "storybook-addon-pseudo-states": "^10.4.6",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wrangler": "4.107.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 128",
    "safari >= 16.4",
    "ios_saf >= 16.4"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
