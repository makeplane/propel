{
  "name": "@plane/propel",
  "version": "0.0.0",
  "description": "Plane's React component library built on Base UI and Tailwind CSS v4.",
  "keywords": [
    "base-ui",
    "components",
    "design-system",
    "plane",
    "react",
    "tailwindcss",
    "ui"
  ],
  "homepage": "https://github.com/makeplane/propel/tree/main/packages/propel#readme",
  "bugs": "https://github.com/makeplane/propel/issues",
  "license": "AGPL-3.0-only",
  "author": "Plane (https://plane.so)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makeplane/propel.git",
    "directory": "packages/propel"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*/index.d.ts",
      "import": "./dist/hooks/*/index.js"
    },
    "./styles": "./dist/styles/propel.css",
    "./styles/*": "./dist/styles/*.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build",
    "test": "vp test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.18.0",
    "react-day-picker": "^10.0.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.4.5",
    "@storybook/addon-vitest": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitest/browser-playwright": "4.1.9",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.5",
    "storybook-addon-pseudo-states": "^10.4.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "4.1.9",
    "wrangler": "4.100.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
